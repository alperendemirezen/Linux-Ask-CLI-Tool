#!/bin/bash

# Send prompts to model with API.
# -----------------------------------------------

# Checking required environment variables
if [ -z "$ASK_API_URL" ] || [ -z "$ASK_MODEL" ] || [ -z "$ASK_API_KEY" ]; then
    echo "Error: ASK_API_URL, ASK_MODEL and ASK_API_KEY must be set!" >&2
    exit 1
fi

# Building the user prompt from arguments and piped stdin
args_prompt="$*"
stdin_prompt=""

# If there is pipe
if [ ! -t 0 ]; then
    stdin_prompt="$(cat)"
fi

# If there is both pipe and stdin
if [ -n "$args_prompt" ] && [ -n "$stdin_prompt" ]; then
    user_prompt="${args_prompt}"$'\n'"${stdin_prompt}"
else
    user_prompt="${args_prompt}${stdin_prompt}"
fi

# If there is no prompt
if [ -z "$user_prompt" ]; then
    echo "Error: Prompt is empty. Enter a prompt!" >&2
    exit 1
fi

# System prompt
system_prompt="You are a CLI tool. Output plain text only. No yapping. Keep the output concise."

# Building the JSON payload with jq
payload=$(jq -n \
    --arg model "$ASK_MODEL" \
    --arg system "$system_prompt" \
    --arg user "$user_prompt" \
    '{
        model: $model,
        messages: [
            { role: "system", content: $system },
            { role: "user",   content: $user   }
        ]
    }')

# Send the request
response=$(curl -sS "$ASK_API_URL" \
    -H "Content-Type: application/json" \
    -H "Authorization: Bearer $ASK_API_KEY" \
    -d "$payload")

# Extract and print the reply
reply=$(echo "$response" | jq -r '.choices[0].message.content // empty')

# If there is no reply
if [ -z "$reply" ]; then
    echo "Error: No reply received!" >&2
    exit 1
fi

echo "$reply"
